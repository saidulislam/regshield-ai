{
  "name": "RegShield - New Change Notification",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "new-change",
        "responseMode": "lastNode"
      },
      "name": "Webhook - New Change",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.client_tier}}",
              "operation": "equals",
              "value2": "high_ticket"
            }
          ]
        }
      },
      "name": "Route by Tier",
      "type": "n8n-nodes-base.if",
      "position": [450, 300]
    },
    {
      "parameters": {
        "fromEmail": "alerts@regshield.ai",
        "toEmail": "={{$json.client_email}}",
        "subject": "[URGENT] New Regulatory Change: {{$json.change_title}}",
        "html": "<h2>New Regulatory Change Detected</h2><p><strong>{{$json.change_title}}</strong></p><p>Urgency: {{$json.urgency}} | Impact Score: {{$json.impact_score}}/100</p><p>{{$json.summary}}</p><p><a href='{{$json.portal_url}}'>View in Portal</a></p><hr><p style='color: #94A3B8; font-size: 12px;'>This assessment was generated by AI and will be reviewed by a compliance expert within 48 hours.</p>"
      },
      "name": "Real-time Alert (HT)",
      "type": "n8n-nodes-base.emailSend",
      "position": [650, 200]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "digest_queue",
              "value": "={{$json.change_id}}"
            }
          ]
        }
      },
      "name": "Queue for Weekly Digest (Prod)",
      "type": "n8n-nodes-base.set",
      "position": [650, 400]
    }
  ],
  "connections": {
    "Webhook - New Change": {
      "main": [
        [{ "node": "Route by Tier", "type": "main", "index": 0 }]
      ]
    },
    "Route by Tier": {
      "main": [
        [{ "node": "Real-time Alert (HT)", "type": "main", "index": 0 }],
        [{ "node": "Queue for Weekly Digest (Prod)", "type": "main", "index": 0 }]
      ]
    }
  }
}
