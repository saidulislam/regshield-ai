# RegShield AI - Environment Variables

# Database (required for backend, not needed for frontend-only demo)
DATABASE_URL=postgresql+asyncpg://regshield:regshield@localhost:5432/regshield
REDIS_URL=redis://localhost:6379/0

# AI/LLM (required for backend pipeline)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Email (Resend)
RESEND_API_KEY=re_...
FROM_EMAIL=alerts@regshield.ai

# Auth
JWT_SECRET=your-256-bit-random-hex
MAGIC_LINK_SECRET=your-separate-secret
FRONTEND_URL=http://localhost:3000

# Analytics
NEXT_PUBLIC_UMAMI_WEBSITE_ID=de8db9e8-00a9-48a4-9b22-5d15ab16f957
